---
const navLinks = [
  { href: '/#about', label: 'О казино' },
  { href: '/#games', label: 'Игры' },
  { href: '/#payments', label: 'Платежи' },
  { href: '/#faq', label: 'FAQ' },
];
const ctaUrl = '/go/';
---

<header class="py-4 bg-bg-primary sticky top-0 z-50 border-b border-border">
  <div class="max-w-[1280px] mx-auto px-4 flex items-center justify-between gap-4">
    <a href="/" class="shrink-0">
      <img src="/img/logo.svg" alt="7K Casino" class="w-[100px] h-[42px] object-contain" width="100" height="42">
    </a>

    <nav class="hidden md:flex gap-8 items-center" id="nav-menu">
      {navLinks.map(link => (
        <a href={link.href} class="text-text-secondary text-sm font-semibold hover:text-accent-gold transition-colors whitespace-nowrap">
          {link.label}
        </a>
      ))}
    </nav>

    <div class="hidden md:flex gap-3 items-center" id="auth-buttons">
      <a href={ctaUrl} class="px-6 py-2.5 rounded-lg bg-gradient-to-b from-white to-[#D4D4D4] text-black text-sm font-semibold hover:from-accent-red hover:to-accent-red-dark hover:text-white transition-all">
        Регистрация
      </a>
      <a href={ctaUrl} class="px-6 py-2.5 rounded-lg border-2 border-accent-red text-text-secondary text-sm font-semibold hover:bg-gradient-to-b hover:from-accent-red hover:to-accent-red-dark hover:text-white transition-all">
        Вход
      </a>
    </div>

    <!-- Mobile burger -->
    <button class="md:hidden flex flex-col gap-1.5 p-2 z-[1001]" id="burger-btn" aria-label="Меню">
      <span class="w-6 h-0.5 bg-accent-gold rounded transition-all" id="burger-1"></span>
      <span class="w-6 h-0.5 bg-accent-gold rounded transition-all" id="burger-2"></span>
      <span class="w-6 h-0.5 bg-accent-gold rounded transition-all" id="burger-3"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="fixed inset-0 bg-bg-primary z-[1000] flex flex-col items-center justify-center gap-6 translate-x-full transition-transform duration-300" id="mobile-menu">
    {navLinks.map(link => (
      <a href={link.href} class="text-text-secondary text-lg font-semibold hover:text-accent-gold transition-colors mobile-nav-link">
        {link.label}
      </a>
    ))}
    <div class="flex flex-col gap-3 mt-4 w-60">
      <a href={ctaUrl} class="px-6 py-3 rounded-lg bg-gradient-to-b from-accent-red to-accent-red-dark text-white text-center font-semibold">
        Регистрация
      </a>
      <a href={ctaUrl} class="px-6 py-3 rounded-lg border-2 border-accent-red text-text-secondary text-center font-semibold">
        Вход
      </a>
    </div>
  </div>
</header>

<script>
  const burger = document.getElementById('burger-btn');
  const menu = document.getElementById('mobile-menu');
  const links = document.querySelectorAll('.mobile-nav-link');

  burger?.addEventListener('click', () => {
    menu?.classList.toggle('translate-x-full');
    menu?.classList.toggle('translate-x-0');
    document.body.style.overflow = menu?.classList.contains('translate-x-0') ? 'hidden' : '';
  });

  links.forEach(link => {
    link.addEventListener('click', () => {
      menu?.classList.add('translate-x-full');
      menu?.classList.remove('translate-x-0');
      document.body.style.overflow = '';
    });
  });
</script>
