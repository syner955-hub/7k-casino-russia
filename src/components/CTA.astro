---
interface Props {
  primary?: boolean;
  text?: string;
  href?: string;
}
const { primary = true, text = 'Играть', href = '/go/' } = Astro.props;
---

<a
  href={href}
  class:list={[
    'inline-block px-8 py-3.5 rounded-lg font-semibold text-base transition-all hover:-translate-y-0.5',
    primary
      ? 'bg-gradient-to-b from-accent-red to-accent-red-dark text-white hover:shadow-[0_5px_20px_rgba(207,3,28,0.5)]'
      : 'border-2 border-accent-red text-text-secondary hover:bg-gradient-to-b hover:from-accent-red hover:to-accent-red-dark hover:text-white'
  ]}
>
  {text}
</a>
