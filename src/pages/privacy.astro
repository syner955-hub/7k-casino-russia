---

<BaseLayout title={title} description={description} canonical="https://7k-casino-russia.it.com/privacy/">
  <Header slot="header" />

  <section class="py-10 px-4">
    <div class="max-w-[800px] mx-auto">
      <h1 class="text-2xl font-bold text-accent-gold mb-6">Политика конфиденциальности</h1>
