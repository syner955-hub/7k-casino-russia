---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Перейти на 7К Казино — официальная ссылка';
const description = 'Переход на официальный сайт 7К Казино. Безопасная ссылка для входа и регистрации.';
const currentDomain = '7k-casino-russia.it.com';
const redirectUrl = `https://win-halllucky.com/l/69d4bae2d788d3223f0a2a02?sub_id=new7k`;
---

<BaseLayout title={title} description={description} canonical="https://7k-casino-russia.it.com/play/">
  <Header slot="header" />

  <section class="py-20 px-4">
    <div class="max-w-[600px] mx-auto text-center">
      <h1 class="text-2xl font-bold text-accent-gold mb-4">Переход на 7К Казино</h1>
      <p class="text-text-secondary text-sm mb-8">Вы будете перенаправлены на официальный сайт 7K Casino. Убедитесь, что вам исполнилось 18 лет.</p>
      
      <div class="bg-bg-card rounded-xl p-8">
        <p class="text-text-muted text-xs mb-6">Нажимая кнопку, вы подтверждаете, что вам есть 18 лет и вы принимаете правила казино.</p>
        <a href={redirectUrl} class="inline-block px-10 py-4 rounded-lg bg-gradient-to-b from-accent-red to-accent-red-dark text-white font-bold text-lg hover:-translate-y-0.5 hover:shadow-[0_5px_20px_rgba(207,3,28,0.5)] transition-all" rel="nofollow">
          Перейти на сайт 7К
        </a>
      </div>

      <p class="text-text-dim text-xs mt-6">Играйте ответственно. Азартные игры могут вызывать зависимость.</p>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<script define:vars={{ redirectUrl }}>
  // Auto-redirect after 3 seconds
  setTimeout(() => {
    window.location.href = redirectUrl;
  }, 3000);
</script>
