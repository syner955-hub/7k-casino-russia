---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SlotCard from '../components/SlotCard.astro';
import FAQ from '../components/FAQ.astro';
import CTA from '../components/CTA.astro';

import slotsData from '../data/slots.json';
import bonusesData from '../data/bonuses.json';
import paymentsData from '../data/payments.json';
import mirrorsData from '../data/mirrors.json';

const title = '7К Казино — официальный сайт | Вход и регистрация 7K Casino 2026';
const description = 'Официальный сайт 7К Казино — вход и регистрация. Рабочее зеркало, бонус 100% + 100 FS, вывод от 15 минут. Как отличить от фейка. Лицензия Curacao.';
const ctaUrl = '/play/';

const faqItems = [
  {
    question: 'Что делать, если сайт 7К казино не открывается?',
    answer: 'Используйте актуальное зеркало с этой страницы или подпишитесь на Telegram-канал 7К, где публикуются свежие ссылки. Также можно использовать VPN или сменить DNS на 1.1.1.1 (Cloudflare) или 8.8.8.8 (Google).'
  },
  {
    question: 'Можно ли играть без верификации?',
    answer: 'Да, играть и пополнять счёт можно без верификации. Она потребуется при первом выводе свыше 20 000 ₽ или при подозрении на мультиаккаунт. Рекомендуем пройти верификацию сразу — это ускорит будущие выводы.'
  },
  {
    question: 'Какой минимальный вывод из 7К казино?',
    answer: 'Минимальная сумма вывода — 500 ₽ (или 10 USD). Для криптовалюты — эквивалент 1 000 ₽. Вывод обрабатывается от 15 минут до 24 часов в зависимости от метода.'
  },
  {
    question: 'Блокирует ли банк переводы из казино?',
    answer: 'Некоторые банки РФ могут отклонять транзакции. В этом случае используйте СБП (работает через большинство банков), криптовалюту (USDT TRC-20 — самый быстрый вариант) или электронные кошельки.'
  },
  {
    question: 'Как отменить бонус в 7К казино?',
    answer: 'Бонус можно отменить в личном кабинете в разделе «Бонусы» до начала отыгрыша. После первой ставки с бонусными средствами отмена невозможна — придётся отыграть вейджер или потерять бонусный баланс.'
  },
  {
    question: 'Работает ли 7К казино с криптовалютой из РФ?',
    answer: 'Да. Поддерживаются BTC, ETH, USDT (TRC-20 и ERC-20), LTC. Крипто-депозиты не зависят от банковских ограничений. USDT TRC-20 — оптимальный вариант: низкая комиссия сети и быстрое подтверждение.'
  }
];
---

<BaseLayout title={title} description={description}>
  <Header slot="header" />

  <!-- Hero -->
  <section class="py-5 px-4">
    <div class="max-w-[1280px] mx-auto">
      <div class="relative rounded-2xl overflow-hidden bg-cover bg-center min-h-[320px] md:min-h-[400px]" style="background-image: url('/img/bg-1.png');">
        <div class="absolute inset-0 bg-gradient-to-r from-black/60 to-black/20"></div>
        <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-8 p-8 md:p-12">
          <div class="flex-1 max-w-lg">
            <h1 class="text-3xl md:text-4xl font-bold leading-tight mb-4">7К Казино — официальный сайт</h1>
            <p class="text-text-secondary text-base mb-6">Вход и регистрация. Бонус 100% + 100 FS на первый депозит.</p>
            <div class="flex flex-wrap gap-3">
              <CTA text="Регистрация" href={ctaUrl} />
              <CTA text="Вход" href={ctaUrl} primary={false} />
            </div>
          </div>
          <div class="hidden md:block max-w-[300px]">
            <img src="/img/bg-2.png" alt="7K Casino" class="w-full h-auto drop-shadow-2xl" width="300" height="300">
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust signals -->
  <section class="py-8 px-4" id="about">
    <div class="max-w-[1280px] mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-bg-card rounded-xl p-5 border border-border">
          <p class="text-accent-gold font-semibold text-sm mb-2">Лицензия Curacao</p>
          <p class="text-text-muted text-xs">№ 8048/JAZ2021-047 (Antillephone N.V.) — международный регулятор с 1996 года</p>
        </div>
        <div class="bg-bg-card rounded-xl p-5 border border-border">
          <p class="text-accent-gold font-semibold text-sm mb-2">Вывод от 15 минут</p>
          <p class="text-text-muted text-xs">СБП, карты, крипто. Минимум 500 ₽. Без скрытых комиссий.</p>
        </div>
        <div class="bg-bg-card rounded-xl p-5 border border-border">
          <p class="text-accent-gold font-semibold text-sm mb-2">7000+ игр</p>
          <p class="text-text-muted text-xs">Pragmatic Play, NetEnt, Evolution, Play'n GO и 200+ провайдеров</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How to identify official site -->
  <section class="py-10 px-4">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-accent-gold text-center mb-8">Как убедиться, что вы на официальном сайте 7К</h2>
      <p class="text-text-secondary text-sm text-center mb-6">Так выглядит настоящий интерфейс 7К казино на мобильном:</p>
      <div class="flex flex-wrap justify-center gap-4 mb-8">
        <img src="/img/screen-main.jpg" alt="Главная страница 7К казино" class="w-[200px] rounded-lg border border-border" loading="lazy">
        <img src="/img/screen-register.jpg" alt="Регистрация в 7К казино" class="w-[200px] rounded-lg border border-border" loading="lazy">
        <img src="/img/screen-cabinet.jpg" alt="Личный кабинет 7К казино" class="w-[200px] rounded-lg border border-border" loading="lazy">
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-bg-card rounded-xl p-6">
          <h3 class="text-accent-gold font-semibold mb-4">Признаки настоящего сайта</h3>
          <ul class="space-y-3">
            {mirrorsData.signs.official.map(sign => (
              <li class="flex items-start gap-3 text-text-secondary text-sm">
                <span class="text-green-400 shrink-0 mt-0.5">✓</span>
                <span>{sign}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-bg-card rounded-xl p-6">
          <h3 class="text-accent-gold font-semibold mb-4">Красные флаги фейков</h3>
          <ul class="space-y-3">
            {mirrorsData.signs.fake.map(sign => (
              <li class="flex items-start gap-3 text-text-secondary text-sm">
                <span class="text-red-400 shrink-0 mt-0.5">✗</span>
                <span>{sign}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Mirror section -->
  <section class="py-10 px-4">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-accent-gold text-center mb-6">Рабочее зеркало 7К казино 2026</h2>
      <div class="bg-bg-card rounded-xl p-6 max-w-2xl mx-auto">
        <p class="text-text-secondary text-sm mb-4">{mirrorsData.whyMirrorsChange}</p>
        <div class="bg-bg-primary rounded-lg p-4 mb-4">
          {mirrorsData.mirrors.map(mirror => (
            <div class="flex items-center justify-between">
              <span class="text-white font-semibold">{mirror.url}</span>
              <span class="text-green-400 text-xs font-semibold px-2 py-1 bg-green-400/10 rounded">Активно</span>
            </div>
          ))}
        </div>
        <h3 class="text-accent-gold text-sm font-semibold mb-2">Как найти актуальное зеркало:</h3>
        <ul class="space-y-2">
          {mirrorsData.howToFind.map(item => (
            <li class="text-text-muted text-sm flex items-start gap-2">
              <span class="text-accent-gold">→</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      <div class="text-center mt-6">
        <a href="/zerkalo/" class="text-accent-gold text-sm underline hover:no-underline">Подробнее о зеркалах и обходе блокировок →</a>
      </div>
      </div>
    </div>
  </section>

  <!-- Registration steps -->
  <section class="py-10 px-4">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-accent-gold text-center mb-8">Регистрация с телефона — 5 шагов</h2>
      <div class="space-y-3 max-w-2xl mx-auto mb-8">
        <div class="bg-bg-card rounded-xl p-5 flex items-start gap-4">
          <span class="bg-gradient-to-b from-accent-red to-accent-red-dark text-white w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold shrink-0">1</span>
          <div>
            <p class="text-white font-semibold text-sm mb-1">Откройте сайт 7К казино</p>
            <p class="text-text-muted text-xs">Используйте ссылку с этой страницы или актуальное зеркало. В адресной строке должен быть замок (SSL).</p>
          </div>
        </div>
        <div class="bg-bg-card rounded-xl p-5 flex items-start gap-4">
          <span class="bg-gradient-to-b from-accent-red to-accent-red-dark text-white w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold shrink-0">2</span>
          <div>
            <p class="text-white font-semibold text-sm mb-1">Нажмите «Регистрация»</p>
            <p class="text-text-muted text-xs">Кнопка в правом верхнем углу. На мобильном — в шапке сайта.</p>
          </div>
        </div>
        <div class="bg-bg-card rounded-xl p-5 flex items-start gap-4">
          <span class="bg-gradient-to-b from-accent-red to-accent-red-dark text-white w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold shrink-0">3</span>
          <div>
            <p class="text-white font-semibold text-sm mb-1">Заполните форму</p>
            <p class="text-text-muted text-xs">E-mail, пароль (от 8 символов), валюта — RUB для России. Можно через соцсети.</p>
          </div>
        </div>
        <div class="bg-bg-card rounded-xl p-5 flex items-start gap-4">
          <span class="bg-gradient-to-b from-accent-red to-accent-red-dark text-white w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold shrink-0">4</span>
          <div>
            <p class="text-white font-semibold text-sm mb-1">Подтвердите аккаунт</p>
            <p class="text-text-muted text-xs">Ссылка придёт на почту. Не пришло — проверьте «Спам» или запросите повторно.</p>
          </div>
        </div>
        <div class="bg-bg-card rounded-xl p-5 flex items-start gap-4">
          <span class="bg-gradient-to-b from-accent-red to-accent-red-dark text-white w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold shrink-0">5</span>
          <div>
            <p class="text-white font-semibold text-sm mb-1">Пополните счёт и активируйте бонус</p>
            <p class="text-text-muted text-xs">Мин. депозит 100 ₽. Введите промокод 7KPROMO2025 при первом пополнении.</p>
          </div>
        </div>
      </div>

      <!-- Common mistakes -->
      <div class="bg-bg-card rounded-xl p-6 max-w-2xl mx-auto">
        <h3 class="text-accent-gold font-semibold mb-4">Частые ошибки при регистрации</h3>
        <ul class="space-y-3">
          <li class="flex items-start gap-2 text-text-secondary text-sm"><span class="text-red-400">✗</span> <span><strong class="text-white">Чужой e-mail</strong> — не сможете подтвердить аккаунт и восстановить пароль</span></li>
          <li class="flex items-start gap-2 text-text-secondary text-sm"><span class="text-red-400">✗</span> <span><strong class="text-white">Не та валюта</strong> — изменить после регистрации нельзя</span></li>
          <li class="flex items-start gap-2 text-text-secondary text-sm"><span class="text-red-400">✗</span> <span><strong class="text-white">Второй аккаунт</strong> — мультиаккаунты запрещены, оба заблокируют</span></li>
          <li class="flex items-start gap-2 text-text-secondary text-sm"><span class="text-red-400">✗</span> <span><strong class="text-white">Не ввели промокод</strong> — активировать после первого депозита уже нельзя</span></li>
        </ul>
      </div>
      <div class="text-center mt-6">
        <a href="/registraciya/" class="text-accent-gold text-sm underline hover:no-underline">Подробная инструкция по регистрации →</a>
      </div>
    </div>
  </section>

  <!-- Bonuses -->
  <section class="py-10 px-4">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-accent-gold text-center mb-8">Бонусы 7К казино — условия и ограничения</h2>
      
      <!-- Promo code -->
      <div class="bg-gradient-to-r from-accent-red/20 to-accent-red-dark/20 border border-accent-red/30 rounded-xl p-5 max-w-2xl mx-auto mb-8 text-center">
        <p class="text-text-secondary text-sm mb-2">Промокод при регистрации:</p>
        <p class="text-accent-gold text-2xl font-bold tracking-wider">{bonusesData.promoCode}</p>
        <p class="text-text-muted text-xs mt-2">{bonusesData.promoCodeBonus}</p>
      </div>

      <!-- Bonus table -->
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-bg-card text-accent-gold">
              <th class="px-4 py-3 text-left font-semibold">Бонус</th>
              <th class="px-4 py-3 text-left font-semibold">Размер</th>
              <th class="px-4 py-3 text-left font-semibold">Вейджер</th>
              <th class="px-4 py-3 text-left font-semibold">Макс. ставка</th>
              <th class="px-4 py-3 text-left font-semibold">Срок</th>
            </tr>
          </thead>
          <tbody>
            {bonusesData.bonuses.map(bonus => (
              <tr class="border-b border-border hover:bg-bg-card/50">
                <td class="px-4 py-3 text-white font-semibold">{bonus.name}</td>
                <td class="px-4 py-3 text-text-secondary">{bonus.amount}</td>
                <td class="px-4 py-3 text-text-secondary">{bonus.wager}</td>
                <td class="px-4 py-3 text-text-secondary">{bonus.maxBet}</td>
                <td class="px-4 py-3 text-text-secondary">{bonus.expiry}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- When bonus is not worth it -->
      <div class="bg-bg-card rounded-xl p-6 mt-8 max-w-2xl mx-auto">
        <h3 class="text-accent-gold font-semibold mb-4">Когда бонус невыгоден — расчёт</h3>
        <p class="text-text-secondary text-sm mb-4">Вейджер x35 означает: при депозите 1 000 ₽ и бонусе 1 000 ₽ нужно прокрутить ставками 2 000 × 35 = <strong class="text-white">70 000 ₽</strong> за 7 дней. При средней ставке 50 ₽ это 1 400 спинов. При RTP 96% статистический проигрыш составит ~2 800 ₽.</p>
        <ul class="space-y-2 mb-4">
          <li class="flex items-start gap-2 text-text-secondary text-sm"><span class="text-red-400">✗</span> Планируете вывести быстро — вейджер блокирует вывод</li>
          <li class="flex items-start gap-2 text-text-secondary text-sm"><span class="text-red-400">✗</span> Играете в слоты с RTP ниже 95% — отыгрыш съест больше</li>
          <li class="flex items-start gap-2 text-text-secondary text-sm"><span class="text-red-400">✗</span> Макс. ставка 500 ₽ ограничивает — при превышении бонус аннулируется</li>
        </ul>
        <p class="text-accent-gold text-xs italic">Совет: если не уверены — откажитесь от бонуса и играйте на свои. Вывод без вейджера быстрее и проще.</p>
      </div>
      <div class="text-center mt-6">
        <a href="/bonusy/" class="text-accent-gold text-sm underline hover:no-underline">Подробнее о бонусах и промокодах →</a>
      </div>
    </div>
  </section>

  <!-- Payments -->
  <section class="py-10 px-4" id="payments">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-accent-gold text-center mb-8">Вывод денег из 7К казино</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-bg-card text-accent-gold">
              <th class="px-4 py-3 text-left font-semibold">Метод</th>
              <th class="px-4 py-3 text-left font-semibold">Мин. вывод</th>
              <th class="px-4 py-3 text-left font-semibold">Макс. вывод</th>
              <th class="px-4 py-3 text-left font-semibold">Срок</th>
              <th class="px-4 py-3 text-left font-semibold">Комиссия</th>
            </tr>
          </thead>
          <tbody>
            {paymentsData.methods.map(method => (
              <tr class="border-b border-border hover:bg-bg-card/50">
                <td class="px-4 py-3 text-white font-semibold">{method.name}</td>
                <td class="px-4 py-3 text-text-secondary">{method.minWithdraw}</td>
                <td class="px-4 py-3 text-text-secondary">{method.maxWithdraw}</td>
                <td class="px-4 py-3 text-text-secondary">{method.withdrawTime}</td>
                <td class="px-4 py-3 text-text-secondary">{method.commission}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Verification block -->
      <div class="bg-bg-card rounded-xl p-6 mt-6 max-w-2xl mx-auto">
        <h3 class="text-accent-gold font-semibold mb-3">Верификация</h3>
        <p class="text-text-muted text-sm mb-3"><strong class="text-white">Когда потребуется:</strong> {paymentsData.verification.when}</p>
        <p class="text-text-muted text-sm mb-2"><strong class="text-white">Документы:</strong></p>
        <ul class="space-y-1 mb-3">
          {paymentsData.verification.documents.map(doc => (
            <li class="text-text-muted text-sm pl-4">— {doc}</li>
          ))}
        </ul>
        <p class="text-text-muted text-sm"><strong class="text-white">Срок проверки:</strong> {paymentsData.verification.time}</p>
        <p class="text-accent-gold text-xs mt-3 italic">{paymentsData.verification.tip}</p>
      </div>

      <!-- Why withdrawal can be rejected -->
      <div class="bg-bg-card rounded-xl p-6 mt-6 max-w-2xl mx-auto">
        <h3 class="text-accent-gold font-semibold mb-3">Почему могут отклонить вывод</h3>
        <ul class="space-y-2">
          <li class="flex items-start gap-2 text-text-secondary text-sm"><span class="text-red-400">✗</span> Не пройдена верификация при сумме свыше 20 000 ₽</li>
          <li class="flex items-start gap-2 text-text-secondary text-sm"><span class="text-red-400">✗</span> Активный бонус с незавершённым вейджером</li>
          <li class="flex items-start gap-2 text-text-secondary text-sm"><span class="text-red-400">✗</span> Подозрение на мультиаккаунт или фрод</li>
          <li class="flex items-start gap-2 text-text-secondary text-sm"><span class="text-red-400">✗</span> Вывод на реквизиты, отличные от тех, с которых пополняли</li>
          <li class="flex items-start gap-2 text-text-secondary text-sm"><span class="text-red-400">✗</span> Сумма ниже минимального лимита</li>
        </ul>
      </div>

      <!-- What to do if delayed -->
      <div class="bg-bg-card rounded-xl p-6 mt-6 max-w-2xl mx-auto">
        <h3 class="text-accent-gold font-semibold mb-3">Что делать при задержке вывода</h3>
        <ol class="space-y-2 text-text-secondary text-sm list-decimal list-inside">
          <li>Проверьте статус в личном кабинете → «История транзакций»</li>
          <li>Убедитесь, что верификация пройдена (если требовалась)</li>
          <li>Проверьте, нет ли активного бонуса с невыполненным вейджером</li>
          <li>Если прошло более 24 часов — напишите в поддержку с номером заявки</li>
        </ol>
      </div>

      <!-- Recommendation for RF -->
      <div class="bg-gradient-to-r from-accent-red/10 to-accent-red-dark/10 border border-accent-red/20 rounded-xl p-5 mt-6 max-w-2xl mx-auto">
        <p class="text-accent-gold font-semibold text-sm mb-2">Рекомендация для игроков из РФ:</p>
        <p class="text-text-secondary text-sm"><strong class="text-white">СБП</strong> — самый надёжный способ. Работает через большинство банков. Если банк блокирует — используйте <strong class="text-white">USDT TRC-20</strong>: комиссия сети ~1 ₽, подтверждение за 5-15 секунд, не зависит от банковских ограничений.</p>
      </div>
      <div class="text-center mt-6">
