---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTA from '../components/CTA.astro';

const title = 'Регистрация в 7К Казино — пошаговая инструкция с мобильного';
const description = 'Как зарегистрироваться в 7К Казино с телефона за 1 минуту. Пошаговая инструкция, какие данные нужны, частые ошибки и их решение.';
const ctaUrl = '/play/';
---

<BaseLayout title={title} description={description} canonical="https://7k-casino-russia.it.com/registraciya/">
  <Header slot="header" />

  <section class="py-10 px-4">
    <div class="max-w-[900px] mx-auto">
      <h1 class="text-3xl md:text-4xl font-bold text-accent-gold text-center mb-6">Регистрация в 7К казино с телефона</h1>
      <p class="text-text-secondary text-base text-center mb-8">Создание аккаунта занимает меньше минуты. Вот что нужно сделать:</p>

      <!-- Steps -->
      <div class="space-y-4 mb-10">
        <div class="bg-bg-card rounded-xl p-5 flex items-start gap-4">
          <span class="bg-gradient-to-b from-accent-red to-accent-red-dark text-white w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold shrink-0">1</span>
          <div>
            <p class="text-white font-semibold text-sm mb-1">Откройте сайт 7К казино</p>
            <p class="text-text-muted text-xs">Используйте ссылку с этого сайта или актуальное зеркало. Убедитесь, что в адресной строке есть замок (SSL).</p>
          </div>
        </div>
        <div class="bg-bg-card rounded-xl p-5 flex items-start gap-4">
          <span class="bg-gradient-to-b from-accent-red to-accent-red-dark text-white w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold shrink-0">2</span>
          <div>
            <p class="text-white font-semibold text-sm mb-1">Нажмите «Регистрация»</p>
            <p class="text-text-muted text-xs">Кнопка находится в правом верхнем углу. На мобильном — в шапке сайта.</p>
          </div>
        </div>
        <div class="bg-bg-card rounded-xl p-5 flex items-start gap-4">
          <span class="bg-gradient-to-b from-accent-red to-accent-red-dark text-white w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold shrink-0">3</span>
          <div>
            <p class="text-white font-semibold text-sm mb-1">Заполните форму</p>
            <p class="text-text-muted text-xs">Укажите e-mail, придумайте пароль (от 8 символов), выберите валюту (RUB для России). Можно зарегистрироваться через соцсети — это быстрее.</p>
          </div>
        </div>
        <div class="bg-bg-card rounded-xl p-5 flex items-start gap-4">
          <span class="bg-gradient-to-b from-accent-red to-accent-red-dark text-white w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold shrink-0">4</span>
          <div>
            <p class="text-white font-semibold text-sm mb-1">Подтвердите аккаунт</p>
            <p class="text-text-muted text-xs">На почту придёт письмо с ссылкой. Если не пришло — проверьте «Спам» или запросите повторно.</p>
          </div>
        </div>
        <div class="bg-bg-card rounded-xl p-5 flex items-start gap-4">
          <span class="bg-gradient-to-b from-accent-red to-accent-red-dark text-white w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold shrink-0">5</span>
          <div>
            <p class="text-white font-semibold text-sm mb-1">Пополните счёт и активируйте бонус</p>
            <p class="text-text-muted text-xs">Минимальный депозит — 100 ₽. При первом пополнении введите промокод 7KPROMO2025 для получения бонуса 100% + 100 FS.</p>
          </div>
        </div>
      </div>

      <!-- What you need -->
      <h2 class="text-xl font-bold text-accent-gold mb-4">Какие данные нужны для регистрации</h2>
      <div class="bg-bg-card rounded-xl p-5 mb-8">
        <ul class="space-y-2 text-text-secondary text-sm">
          <li>— Действующий e-mail (для подтверждения и восстановления пароля)</li>
          <li>— Пароль от 8 символов (рекомендуем буквы + цифры)</li>
          <li>— Выбор валюты (нельзя изменить после регистрации!)</li>
          <li>— Возраст 18+ (проверяется при верификации)</li>
        </ul>
      </div>

      <!-- Common mistakes -->
      <h2 class="text-xl font-bold text-accent-gold mb-4">Частые ошибки при регистрации</h2>
      <div class="bg-bg-card rounded-xl p-5 mb-8">
        <ul class="space-y-3 text-text-secondary text-sm">
          <li class="flex items-start gap-2">
            <span class="text-red-400 shrink-0">✗</span>
            <span><strong class="text-white">Указали чужой e-mail</strong> — не сможете подтвердить аккаунт и восстановить пароль</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-red-400 shrink-0">✗</span>
            <span><strong class="text-white">Выбрали не ту валюту</strong> — изменить после регистрации нельзя, придётся создавать новый аккаунт</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-red-400 shrink-0">✗</span>
            <span><strong class="text-white">Создали второй аккаунт</strong> — мультиаккаунты запрещены, оба будут заблокированы</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-red-400 shrink-0">✗</span>
            <span><strong class="text-white">Не активировали бонус</strong> — промокод нужно ввести при первом депозите, потом уже не сработает</span>
          </li>
        </ul>
      </div>

      <div class="text-center">
        <CTA text="Зарегистрироваться" href={ctaUrl} />
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
