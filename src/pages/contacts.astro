---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Контакты — 7К Казино официальный сайт';
const description = 'Контактная информация сайта 7К Казино. Свяжитесь с нами по email, Telegram или через форму обратной связи.';
---

<BaseLayout title={title} description={description} canonical="https://7k-casino-russia.it.com/contacts/">
  <Header slot="header" />

  <section class="py-10 px-4">
    <div class="max-w-[800px] mx-auto">
      <h1 class="text-2xl font-bold text-accent-gold mb-6">Контакты</h1>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <div class="bg-bg-card rounded-xl p-6 border border-border">
          <h2 class="text-white font-semibold text-base mb-4">Редакция сайта</h2>
          <ul class="space-y-3 text-text-secondary text-sm">
            <li class="flex items-start gap-3">
              <span class="text-accent-gold shrink-0">✉</span>
              <span>Email: <a href="mailto:support@7k-casino-russia.it.com" class="text-accent-gold">support@7k-casino-russia.it.com</a></span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent-gold shrink-0">✈</span>
              <span>Telegram: <a href="https://t.me/casino_7k_official_ru" class="text-accent-gold">@casino_7k_official_ru</a></span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent-gold shrink-0">⏰</span>
              <span>Время ответа: до 24 часов</span>
            </li>
          </ul>
        </div>

        <div class="bg-bg-card rounded-xl p-6 border border-border">
          <h2 class="text-white font-semibold text-base mb-4">Юридическая информация</h2>
          <ul class="space-y-3 text-text-secondary text-sm">
            <li class="flex items-start gap-3">
              <span class="text-accent-gold shrink-0">🏢</span>
              <span>Digital Media Group Ltd.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent-gold shrink-0">📍</span>
              <span>Schout Bij Nacht Doormanweg 40, Curaçao</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent-gold shrink-0">📋</span>
              <span>Reg. No: 163842</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Map -->
      <div class="mb-8">
        <h2 class="text-lg font-semibold text-white mb-4">Наш офис</h2>
        <div class="rounded-xl overflow-hidden border border-border">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3889.5!2d-68.9698!3d12.1696!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8e8483f0a3b3b3b3%3A0x1234567890abcdef!2sSchout+Bij+Nacht+Doormanweg+40%2C+Cura%C3%A7ao!5e0!3m2!1sen!2s!4v1716048000000!5m2!1sen!2s"
            width="100%"
            height="300"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            class="w-full">
          </iframe>
        </div>
      </div>

      <!-- Contact reasons -->
      <div class="bg-bg-card rounded-xl p-6">
        <h2 class="text-white font-semibold text-base mb-4">По каким вопросам можно обращаться</h2>
        <ul class="space-y-2 text-text-secondary text-sm">
          <li class="flex items-start gap-2"><span class="text-accent-gold">→</span> Актуальные зеркала и проблемы с доступом</li>
          <li class="flex items-start gap-2"><span class="text-accent-gold">→</span> Вопросы по бонусам и промокодам</li>
          <li class="flex items-start gap-2"><span class="text-accent-gold">→</span> Сообщить об ошибке на сайте</li>
          <li class="flex items-start gap-2"><span class="text-accent-gold">→</span> Предложения по сотрудничеству</li>
          <li class="flex items-start gap-2"><span class="text-accent-gold">→</span> Запрос на удаление персональных данных</li>
        </ul>
        <p class="text-text-muted text-xs mt-4">Обратите внимание: мы не являемся службой поддержки казино. По вопросам вывода средств, верификации и блокировки аккаунта обращайтесь напрямую в поддержку 7К казино через онлайн-чат на сайте оператора.</p>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
